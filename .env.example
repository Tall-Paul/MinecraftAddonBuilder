# CurseForge API key - get one free at https://console.curseforge.com/
CURSEFORGE_API_KEY=your_api_key_here

# Port for the web UI (default: 3000)
PORT=3000

# Docker socket path (default: /var/run/docker.sock)
DOCKER_SOCKET=/var/run/docker.sock

# Filter for Bedrock server containers (comma-separated image name substrings)
BEDROCK_IMAGE_FILTER=itzg/minecraft-bedrock-server,bedrock

# Cache directory for downloaded addons
CACHE_DIR=/app/data/cache

# Database path
DB_PATH=/app/data/addons.db

# GitHub Personal Access Token for auto-updater (optional, needed for private repos)
# Create one at https://github.com/settings/tokens with 'repo' scope
GIT_TOKEN=
